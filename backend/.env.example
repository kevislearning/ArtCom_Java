# Database Connection (Aiven PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://<your-database-host>:<port>/<db-name>?sslmode=require
SPRING_DATASOURCE_USERNAME=your_username
SPRING_DATASOURCE_PASSWORD=your_password

# JWT & Client Configuration
JWT_SECRET=your_jwt_secret_key_here
CLIENT_URL=http://localhost:5173

# MoMo Sandbox Credentials
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create

# VietQR Bank Credentials
BANK_ID=your_bank_id_here
BANK_ACCOUNT_NO=your_bank_account_number
BANK_ACCOUNT_NAME=your_bank_account_name

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id

# Hugging Face Space AI custom model
HF_TOKEN=your_hugging_face_token
HF_SPACE_URL=your_hugging_face_space_url
AI_DETECTION_THRESHOLD=0.65
