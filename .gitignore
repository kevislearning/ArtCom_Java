# =========================================================================
#                 GLOBAL .GITIGNORE FOR ART-GALLERY PLATFORM
# =========================================================================
# Coordinated ignore configuration covering both Backend (Java/Maven)
# and Frontend (Node/React/Vite) as well as common OS and IDE files.
# =========================================================================

# -------------------------------------------------------------------------
# 1. ENVIRONMENT VARIABLES & SECRETS (CRITICAL - DO NOT PUSH TO GITHUB)
# -------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
!.env.example

# -------------------------------------------------------------------------
# 2. KEYSTORES, CERTIFICATES & DATABASE DUMPS
# -------------------------------------------------------------------------
*.jks
*.p12
*.pem
*.key
*.sql
*.sqlite
*.db

# -------------------------------------------------------------------------
# 3. BACKEND - JAVA & MAVEN SPECIFIC (backend/)
# -------------------------------------------------------------------------
# Maven build directory
backend/target/
target/

# Local fallback upload directory (Avoid committing user-uploaded images)
backend/uploads/
uploads/

# Crash logs and general logs
backend/*.log
*.log

# Hotspot VM logs
hs_err_pid*
replay_pid*

# -------------------------------------------------------------------------
# 4. FRONTEND - NODE & REACT SPECIFIC (frontend/)
# -------------------------------------------------------------------------
# Dependencies
frontend/node_modules/
node_modules/

# Production builds
frontend/dist/
frontend/dist-ssr/
dist/
dist-ssr/

# Package manager logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Next.js/Nuxt.js build output (if any)
.next/
.nuxt/

# -------------------------------------------------------------------------
# 5. IDE, EDITORS & SYSTEM FILES (GLOBAL)
# -------------------------------------------------------------------------
# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Visual Studio Code
.vscode/*
!.vscode/extensions.json
.history/
*.code-workspace

# Eclipse
.metadata/
.classpath
.project
.settings/
*.tmp
*.bak
*.eml
*.userlibraries

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# Operating System specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/
*.lnk
